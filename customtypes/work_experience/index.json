{
  "format": "custom",
  "id": "work_experience",
  "label": "Work Experience",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "e.g. ML Engineer Intern"
        }
      },
      "company": {
        "type": "Text",
        "config": {
          "label": "Company",
          "placeholder": "Company Name"
        }
      },
      "start_date": {
        "type": "Date",
        "config": {
          "label": "Start Date",
          "placeholder": ""
        }
      },
      "end_date": {
        "type": "Date",
        "config": {
          "label": "End Date",
          "placeholder": "Leave empty for current role"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Brief description of role",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item"
        }
      },
      "skills": {
        "type": "Group",
        "config": {
          "label": "Skills",
          "repeat": true,
          "fields": {
            "skill_ref": {
              "type": "Link",
              "config": {
                "label": "Skill Reference",
                "select": "document",
                "customtypes": ["skill"]
              }
            },
            "proficiency": {
              "type": "Number",
              "config": {
                "label": "Proficiency",
                "placeholder": "1-100"
              }
            }
          }
        }
      },
      "concurrent_roles": {
        "type": "Group",
        "config": {
          "label": "Concurrent Roles",
          "repeat": true,
          "fields": {
            "concurrent_ref": {
              "type": "Link",
              "config": {
                "label": "Concurrent Role",
                "select": "document",
                "customtypes": ["work_experience"]
              }
            }
          }
        }
      },
      "node_layer": {
        "type": "Number",
        "config": {
          "label": "Node Layer",
          "placeholder": "Integer 1-N for Z-depth grouping"
        }
      }
    }
  }
}
